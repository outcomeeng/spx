{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":semanticCommitTypeAll(build)",
    ":dependencyDashboard"
  ],
  "timezone": "UTC",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Group and automerge GitHub Actions updates once required checks pass.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github-actions",
      "automerge": true
    },
    {
      "description": "Automerge non-major devDependency updates once required checks pass.",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "dev dependencies (non-major)",
      "automerge": true
    },
    {
      "description": "Hold every major update for manual approval through the dependency dashboard.",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true
    },
    {
      "description": "Bump the pnpm package manager manually.",
      "matchDepNames": ["pnpm"],
      "automerge": false
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "schedule": ["at any time"],
    "minimumReleaseAge": "0 days",
    "packageRules": [
      {
        "description": "Automerge non-major vulnerability fixes once required checks pass.",
        "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
        "automerge": true
      },
      {
        "description": "Hold major vulnerability fixes for manual approval through the dependency dashboard.",
        "matchUpdateTypes": ["major"],
        "automerge": false,
        "dependencyDashboardApproval": true
      }
    ]
  }
}
