# Claude Code plan mode
.claude/*
!.claude/settings.json

# Agent runtime config
.codex/*
!.codex/config.toml

# Dependencies
node_modules/

# Build output
dist/
build/

# Test coverage
coverage/

# Environment
.env
.env.local

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*

# SPX ephemeral local state (sessions, nodes, audit, reviews, testing).
# Per spx/15-worktree-resolution.pdr.md the entire .spx/ tree is gitignored
# and exists only at the Git common-dir product root — ignore it wholesale
# so new subdirectories (e.g. reviews/) do not drift out of coverage.
.spx/

# Generated per-node status files (spx spec status --update); regenerated on
# demand, never committed.
spx.status.json

# Git worktree directories
.work/*
